[MASTER]
# Load Django plugin so pylint understands Django code
load-plugins=pylint_django

# Point to your Django settings
django-settings-module=lms_project.settings

# Ignore auto-generated migration files (no point linting these)
ignore-paths=library/migrations

[MESSAGES CONTROL]
disable=
    # Django models/admin classes naturally have few public methods
    too-few-public-methods,

    # Migration file names like 0001_initial don't follow snake_case — that's fine
    invalid-name,

    # Auto-generated migration files are always missing docstrings — ignore
    missing-module-docstring,

    # Django admin classes don't need docstrings
    missing-class-docstring,

[FORMAT]
# Allow lines up to 120 characters (Django community standard)
max-line-length=120

[DESIGN]
# Allow classes with 0 public methods (normal in Django)
min-public-methods=0